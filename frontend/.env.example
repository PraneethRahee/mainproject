# Backend API base (no trailing slash required by all callers; match your backend PORT)
VITE_API_BASE_URL=http://localhost:4000

# Optional: Socket.IO URL (defaults to apiBaseUrl / same host)
# VITE_SOCKET_URL=http://localhost:4000

# Feature flags (omit to use defaults in src/config/env.js)
# VITE_FEATURE_PUSH_NOTIFICATIONS_ENABLED=true
# VITE_FEATURE_CALLS_ENABLED=true
# VITE_FEATURE_STORIES_ENABLED=true
