NODE_ENV=development
PORT=4000

# MongoDB connection string (do not commit real credentials)
MONGODB_URI=mongodb://127.0.0.1:27017/chatapp

# Redis (optional for local dev; use your deployment URL in production)
REDIS_URL=redis://127.0.0.1:6379

# Generate strong random values for production (min lengths as enforced by app)
JWT_SECRET=change-me-min-32-chars-please-000000
MFA_SECRET=change-me-16-chars-

# Cloudinary (optional; file uploads)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# CORS: comma-separated origins for browser clients (must include your frontend URL)
# CORS_ORIGINS=http://localhost:5173
